<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RomanConverter.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Spacing="25"
            Padding="30,0"
            VerticalOptions="Center">
            <Label Text="Roman Numerals to Numbers"/>
            <Entry x:Name="txtRomanNumeral" Keyboard="Numeric" TextChanged="TxtRomanNumeral_OnTextChanged" />
            
            <StackLayout Orientation="Horizontal" >
                <Button Text="Clear" HorizontalOptions="FillAndExpand" Clicked="btnClear_OnClicked"/>
                <Button Text="Convert" HorizontalOptions="FillAndExpand" Clicked="btnConvert_OnClicked"/>
            </StackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
