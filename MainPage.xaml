<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RomanConverter.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Spacing="25"
            Padding="20,40,20,20"
            VerticalOptions="Center">
            <Label Text="Roman Numerals to Numbers"/>
            <Entry x:Name="txtInput" Keyboard="Numeric" />
            
            <Label x:Name="lblResult" FontSize="40" FontAttributes="Bold"/>
            
            <StackLayout Orientation="Horizontal" >
                <Button Text="Clear" HorizontalOptions="FillAndExpand" Clicked="btnClear_OnClicked" Padding="20"/>
                <Button Text="Convert" HorizontalOptions="FillAndExpand" Clicked="btnConvert_OnClicked"/>
            </StackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
